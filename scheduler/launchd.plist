<?xml version="1.0" encoding="UTF-8"?>
<!-- macOS launchd daily agent. `launchctl load ~/Library/LaunchAgents/com.newsagent.daily.plist` -->
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.newsagent.daily</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/atandrabharati/Desktop/CoreProjects/newsagent &amp;&amp; NEWSAGENT_CADENCE=daily .venv/bin/python -m newsagent news prompts/ai_news_daily.md &gt;&gt; storage/newsagent.log 2&gt;&amp;1</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>6</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/Users/atandrabharati/Desktop/CoreProjects/newsagent/storage/newsagent.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/atandrabharati/Desktop/CoreProjects/newsagent/storage/newsagent.err.log</string>
  </dict>
</plist>
