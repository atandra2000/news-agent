# newsagent environment configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is git-ignored; never commit secrets.

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# Backend selection: ollama | opencode_go | openai
NEWSAGENT_LLM_BACKEND=ollama

# Ollama / Ollama Cloud
NEWSAGENT_LLM_OLLAMA_BASE_URL=https://api.ollama.com
NEWSAGENT_LLM_OLLAMA_API_KEY=
NEWSAGENT_LLM_OLLAMA_MODEL=

# OpenCode Zen / Go (OpenAI-compatible)
NEWSAGENT_LLM_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
NEWSAGENT_LLM_OPENCODE_GO_API_KEY=
NEWSAGENT_LLM_OPENCODE_GO_MODEL=

# OpenAI (optional, for direct OpenAI access)
NEWSAGENT_LLM_OPENAI_API_KEY=
NEWSAGENT_LLM_OPENAI_MODEL=

# -----------------------------------------------------------------------------
# Search backend
# -----------------------------------------------------------------------------
# Backend: tavily | none
# - tavily: paid, richer web results
# - none:   use 7 free collectors (arxiv, hacker_news, github_trending,
#           huggingface, semantic_scholar, devto, lobsters) — no key required
NEWSAGENT_SEARCH_BACKEND=tavily
NEWSAGENT_SEARCH_TAVILY_API_KEY=
NEWSAGENT_SEARCH_TAVILY_BASE_URL=https://api.tavily.com

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Context7 (for library docs lookup). Read directly by the context7 collector
# via os.environ.get("NEWSAGENT_CONTEXT7_API_KEY").
NEWSAGENT_CONTEXT7_API_KEY=

# GitHub token (for higher rate limits on github_trending / github_topic_search / github_releases)
NEWSAGENT_COLLECTOR_GITHUB_TOKEN=

# X / Twitter bearer token (v2 API). Optional — x_twitter collector no-ops
# gracefully if unset. Set this to pull tweets from the curated AI watchlist.
NEWSAGENT_X_BEARER_TOKEN=
