# Hermes environment configuration
# Copy this file to `.env` and fill in your real values.
# `.env` is git-ignored; never commit secrets.

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# Backend selection: ollama | opencode_go | openai
HERMES_LLM_BACKEND=ollama

# Ollama / Ollama Cloud
HERMES_LLM_OLLAMA_BASE_URL=https://api.ollama.com
HERMES_LLM_OLLAMA_API_KEY=
HERMES_LLM_OLLAMA_MODEL=

# OpenCode Zen / Go (OpenAI-compatible)
HERMES_LLM_OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
HERMES_LLM_OPENCODE_GO_API_KEY=
HERMES_LLM_OPENCODE_GO_MODEL=

# OpenAI (optional, for direct OpenAI access)
HERMES_LLM_OPENAI_API_KEY=
HERMES_LLM_OPENAI_MODEL=

# -----------------------------------------------------------------------------
# Search backend
# -----------------------------------------------------------------------------
# Backend: tavily | none
# - tavily: paid, richer web results
# - none:   use 7 free collectors (arxiv, hacker_news, github_trending,
#           huggingface, semantic_scholar, devto, lobsters) — no key required
HERMES_SEARCH_BACKEND=tavily
HERMES_SEARCH_TAVILY_API_KEY=
HERMES_SEARCH_TAVILY_BASE_URL=https://api.tavily.com

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Context7 (for library docs lookup)
HERMES_PIPELINE_CONTEXT7_API_KEY=

# GitHub token (for higher rate limits on github_trending / releases)
HERMES_COLLECTOR_GITHUB_TOKEN=
