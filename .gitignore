# Editors / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# Project-local runtime state at the repo root. `src/hermes/storage/` is the
# SQLAlchemy package and is tracked normally; the runtime `storage/` dir
# holds the SQLite DB, run manifests, vectors, reports, and adapter state.
# The leading slash anchors the pattern so `src/hermes/storage/` is NOT
# matched.
/storage/
.claude/
.superpowers/
.remember/

# Build / packaging
*.egg
*.whl
pip-wheel-metadata/
